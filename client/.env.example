# Base URL of the rex server (consumed by next.config.ts for /v1/* rewrites)
REX_API_BASE=http://localhost:8080

# Public canonical URL of the site. Used by lib/seo.ts for the <link rel="canonical">
# tag, the sitemap, robots.txt host, and Open Graph URLs. Override per-environment:
#   prod      → https://rex.reneducation.com
#   preview   → leave unset; the default points at the production canonical so
#               preview URLs don't accidentally get indexed as the canonical
#               (you also want robots NoIndex on preview, but that's separate)
#   local dev → leave unset; only matters when you're QA'ing meta tags
NEXT_PUBLIC_SITE_URL=https://rex.reneducation.com

# PostHog browser analytics. Matches ren-landing/ren-b2c, but uses Next's
# NEXT_PUBLIC_* prefix so the browser bundle can read it.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
